{
  "$schema": "https://turborepo.dev/schema.json",
  "globalDependencies": [
    "package.json",
    "pnpm-lock.yaml",
    "pnpm-workspace.yaml",
    "turbo.json",
    "scripts/**"
  ],
  "globalPassThroughEnv": [
    "ACTIONS_*",
    "CI",
    "GH_TOKEN",
    "GITHUB_*",
    "NODE_AUTH_TOKEN",
    "NPM_TOKEN"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "fern/.definition/**"
      ]
    },
    "check": {
      "dependsOn": [
        "^check"
      ],
      "outputs": []
    }
  }
}

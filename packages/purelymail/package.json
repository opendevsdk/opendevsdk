{
  "name": "@opendevsdk/purelymail",
  "version": "0.0.1",
  "private": true,
  "publishConfig": {
    "access": "restricted"
  },
  "scripts": {
    "build": "pnpm provision && pnpm definition && pnpm generate",
    "provision": "node ../../scripts/provision.mjs --package-dir .",
    "generate": "fern generate --group typescript --force",
    "definition": "fern write-definition",
    "check": "fern check"
  },
  "packageManager": "pnpm@10.31.0",
  "devDependencies": {
    "fern-api": "4.26.0"
  }
}
